generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-arm64-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  /// Same DB, non-transaction pooler URL (Supabase: Session pooler :5432). Locally copy `DATABASE_URL`.
  directUrl = env("DIRECT_URL")
}

// --- Lifecycle (separate per entity as required) ---

enum OrgGroupStatus {
  ACTIVE
  ARCHIVED
}

enum CompanyStatus {
  ACTIVE
  ARCHIVED
  SUSPENDED
}

enum ProjectStatus {
  PLANNING
  ACTIVE
  AT_RISK
  ON_HOLD
  COMPLETED
  ARCHIVED
  CANCELLED
}

enum WorkflowNodeStatus {
  NOT_STARTED
  IN_PROGRESS
  WAITING
  BLOCKED
  APPROVED
  DONE
  SKIPPED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum WorkflowNodeType {
  MILESTONE
  TASK
  APPROVAL
  WAITING
  COMPLETED
}

enum WorkflowNodeLabel {
  WAITING_ON_RESPONSE
  WAITING_ON_INTERNAL_TEAM_MEMBER
  WAITING_ON_EXTERNAL_PARTY
  WAITING_ON_CLIENT
  WAITING_ON_VENDOR_PARTNER
  WAITING_ON_DOCUMENT_MATERIAL
  PENDING_APPROVAL
  UNDER_REVIEW
  APPROVED
  NEEDS_REVISION
  REJECTED
  AT_RISK
  BLOCKED
  OVERDUE
  PAUSED
}

enum WorkflowEdgeKind {
  DEPENDENCY
  SEQUENTIAL
  BRANCH
  PARALLEL
  LOOPBACK
}

/// Phase 1 uses EXTERNAL_URL; FILE preserves legacy uploads and future binary assets.
enum AttachmentResourceKind {
  FILE
  EXTERNAL_URL
}

enum AuditEntityType {
  ORG_GROUP
  COMPANY
  PROJECT
  USER
  ROLE_DEFINITION
  WORKFLOW_LAYER
  WORKFLOW_NODE
  WORKFLOW_EDGE
  ATTACHMENT
  PERMISSION
  RECOGNITION
  FEEDBACK
  PERFORMANCE
  COMPANION
  KNOWLEDGE
  PROJECT_RELATION
  SCORE_LEDGER
  MEMBER_OUTPUT
  MEMBER_ONBOARDING
  LIFECYCLE_TRIGGER
  OFFBOARDING_RUN
  CALENDAR_EVENT
}

enum RecognitionMode {
  PUBLIC
  SEMI_ANONYMOUS
  ANONYMOUS
}

enum RecognitionTagCategory {
  RESULT
  COLLABORATION
  THINKING
  CREATIVITY
  CULTURE
  STABILITY
  GUIDANCE
}

enum CompanionSpecies {
  BIRD
  BEAR
  PENGUIN
  DOG
  CAT
  BEAVER
  BUNNY
  HAMSTER
}

enum FeedbackCategory {
  COMMUNICATION
  DELIVERY_QUALITY
  FOLLOW_THROUGH
  DOCUMENTATION
  COLLABORATION_RESPONSIVENESS
}

enum AbilityDimension {
  EXECUTION
  COLLABORATION
  JUDGMENT
  CREATIVITY
  KNOWLEDGE
  RELIABILITY
  GUIDANCE
}

enum ScorePolarity {
  POSITIVE
  NEGATIVE
  NEUTRAL
}

enum LeaderboardCategory {
  EXECUTION
  COLLABORATION
  KNOWLEDGE
  RECOGNITION
}

enum KnowledgeLayer {
  TEMPLATE_PLAYBOOK
  REFERENCE_RESOURCE
  INTERNAL_INSIGHT
  REUSABLE_OUTPUT
}

enum ProjectRelationType {
  INDEPENDENT
  PARENT_CHILD
  LINKED
  DEPENDS_ON
  CROSS_COMPANY
  SHARED_ASSET
}

enum LifecycleTriggerKind {
  FEEDBACK
  RECOGNITION
}

enum LifecycleTriggerScope {
  GLOBAL
  COMPANY
}

enum LifecycleCategoryMode {
  TOTAL_COUNT
  ANY_CATEGORY
  /// Each feedback category / recognition tag must reach threshold independently (any one category crossing counts).
  PER_CATEGORY
}

enum OffboardingStatus {
  DRAFT
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum CalendarSourceKind {
  MANUAL
  ONBOARDING
  IMPROVEMENT_TRIGGER
  RECOGNITION_TRIGGER
  OFFBOARDING
}

// --- RBAC: permission matrix (roleDefinitionId + permissionKey) ---

model PermissionDefinition {
  id          String  @id @default(cuid())
  key         String  @unique
  description String?
  category    String?

  rolePermissions RolePermission[]
}

model RolePermission {
  id                     String  @id @default(cuid())
  roleDefinitionId       String
  permissionDefinitionId String
  allowed                Boolean @default(true)

  roleDefinition       RoleDefinition       @relation(fields: [roleDefinitionId], references: [id], onDelete: Cascade)
  permissionDefinition PermissionDefinition @relation(fields: [permissionDefinitionId], references: [id], onDelete: Cascade)

  @@unique([roleDefinitionId, permissionDefinitionId])
  @@index([permissionDefinitionId])
}

// Parent organization (e.g. J.D. Phoebe Group). Stable id; name is editable.
model OrgGroup {
  id           String         @id @default(cuid())
  name         String
  introduction String?
  status       OrgGroupStatus @default(ACTIVE)
  archivedAt   DateTime?
  deletedAt    DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  companies        Company[]
  groupMemberships GroupMembership[]
}

// Sub-company / entity under the group.
model Company {
  id                       String        @id @default(cuid())
  orgGroupId               String
  name                     String
  companyType              String?
  introduction             String?
  /// Public URL or app-relative path to uploaded logo (internal identity).
  logoUrl                  String?
  status                   CompanyStatus @default(ACTIVE)
  /// HR onboarding pack (e.g. Google Drive); shown to new members assigned to this company.
  onboardingPackageUrl     String?
  /// Optional onboarding video URL (direct .mp4 or https page); watch progress is tracked for members.
  onboardingVideoUrl       String?
  onboardingPackageVersion String        @default("v1")
  onboardingDeadlineDays   Int           @default(14)
  archivedAt               DateTime?
  deletedAt                DateTime?
  createdAt                DateTime      @default(now())
  updatedAt                DateTime      @updatedAt

  orgGroup              OrgGroup               @relation(fields: [orgGroupId], references: [id], onDelete: Cascade)
  memberships           CompanyMembership[]
  projects              Project[]
  departments           Department[]
  projectGroups         ProjectGroup[]
  knowledgeAssets       KnowledgeAsset[]
  memberOutputs         MemberOutput[]
  memberOnboardings     MemberOnboarding[]
  offboardingRuns       OffboardingRun[]
  lifecycleTriggerRules LifecycleTriggerRule[]
}

/// Business unit within a company (e.g. Marketing, Compliance).
model Department {
  id        String   @id @default(cuid())
  companyId String
  name      String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company            Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyMemberships CompanyMembership[]
  projects           Project[]

  @@index([companyId])
}

/// User-defined project buckets within a company (collapsible groups on the projects list).
model ProjectGroup {
  id        String   @id @default(cuid())
  companyId String
  name      String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company  Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  projects Project[]

  @@index([companyId])
}

model User {
  id                        String    @id @default(cuid())
  email                     String    @unique
  passwordHash              String?
  clerkId                   String?   @unique
  name                      String
  title                     String?
  /// Extra contact emails (comma / semicolon separated); login email stays in `email`.
  contactEmails             String?
  phone                     String?
  timezone                  String    @default("UTC")
  active                    Boolean   @default(true)
  /// When true, user must change password at /settings/change-password before using the app.
  mustChangePassword        Boolean   @default(false)
  isSuperAdmin              Boolean   @default(false)
  /// Public URL or app-relative path to uploaded avatar.
  avatarUrl                 String?
  /// First-login companion picker completed; null means redirect to onboarding.
  companionIntroCompletedAt DateTime?
  /// First authenticated app session (for onboarding audit).
  firstSignInAt             DateTime?
  /// Recognition trigger: mark member for positive follow-up until this instant.
  positiveAttentionUntil    DateTime?
  deletedAt                 DateTime?
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt

  groupMemberships         GroupMembership[]
  companyMemberships       CompanyMembership[]
  supervisorForMemberships CompanyMembership[]    @relation("MembershipSupervisor")
  projectMemberships       ProjectMembership[]
  nodeAssignments          WorkflowNodeAssignee[]
  waitingOnNodes           WorkflowNode[]         @relation("NodeWaitingOnUser")
  waitingOnNodeLinks       WorkflowNodeWaitingUser[]
  approverForNodes         WorkflowNode[]         @relation("NodeApproverUser")
  ownedProjects            Project[]              @relation("ProjectOwner")
  auditEntries             AuditLogEntry[]        @relation("AuditActor")
  sessions                 Session[]
  attachmentsUploaded      Attachment[]           @relation("AttachmentUploader")
  companionProfile         CompanionProfile?
  recognitionsGiven        RecognitionEvent[]     @relation("RecognitionFrom")
  recognitionsReceived     RecognitionEvent[]     @relation("RecognitionTo")
  feedbackGiven            FeedbackEvent[]        @relation("FeedbackFrom")
  feedbackReceived         FeedbackEvent[]        @relation("FeedbackTo")
  scoreLedgerEntries       ScoreLedgerEntry[]
  performanceSnapshots     PerformanceSnapshot[]
  knowledgeAssets          KnowledgeAsset[]       @relation("KnowledgeAuthor")
  knowledgeReuses          KnowledgeReuseEvent[]  @relation("KnowledgeReuseActor")
  attachmentsAsContributor Attachment[]           @relation("AttachmentContributor")
  memberOutputs            MemberOutput[]
  memberOnboardings        MemberOnboarding[]
  onboardingsAsLiaison     MemberOnboarding[]     @relation("OnboardingLiaison")
  inAppNotifications       InAppNotification[]
  lifecycleReminderLogs    LifecycleReminderLog[]
  lifecycleTriggerFires    LifecycleTriggerFire[]
  organizedCalendarEvents  CalendarEvent[]        @relation("CalendarOrganizer")
  calendarAttendees        CalendarAttendee[]
  offboardingRunsSubject   OffboardingRun[]       @relation("OffboardingSubject")
  offboardingRunsStarted   OffboardingRun[]       @relation("OffboardingStartedBy")
  staffInvitesCreated      StaffInvite[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

/// Pending staff account after admin requests email OTP (consumed when user is created).
model StaffInvite {
  id              String    @id @default(cuid())
  email           String
  name            String
  title           String?
  passwordHash    String
  otpHash         String
  expiresAt       DateTime
  consumedAt      DateTime?
  attempts        Int       @default(0)
  createdByUserId String
  createdAt       DateTime  @default(now())

  createdBy User @relation(fields: [createdByUserId], references: [id], onDelete: Cascade)

  @@index([email])
  @@index([expiresAt])
  @@index([createdByUserId])
}

model RoleDefinition {
  id           String   @id @default(cuid())
  key          String   @unique
  displayName  String
  description  String?
  appliesScope String
  system       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  groupMemberships   GroupMembership[]
  companyMemberships CompanyMembership[]
  projectMemberships ProjectMembership[]
  rolePermissions    RolePermission[]
}

model GroupMembership {
  id               String @id @default(cuid())
  userId           String
  orgGroupId       String
  roleDefinitionId String

  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  orgGroup       OrgGroup       @relation(fields: [orgGroupId], references: [id], onDelete: Cascade)
  roleDefinition RoleDefinition @relation(fields: [roleDefinitionId], references: [id], onDelete: Restrict)

  @@unique([userId, orgGroupId])
  @@index([orgGroupId])
}

model CompanyMembership {
  id               String  @id @default(cuid())
  userId           String
  companyId        String
  roleDefinitionId String
  departmentId     String?
  /// Direct supervisor / onboarding liaison for this membership (HR assigns).
  supervisorUserId String?

  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  company        Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  roleDefinition RoleDefinition @relation(fields: [roleDefinitionId], references: [id], onDelete: Restrict)
  department     Department?    @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  supervisor     User?          @relation("MembershipSupervisor", fields: [supervisorUserId], references: [id], onDelete: SetNull)

  @@unique([userId, companyId])
  @@index([companyId])
  @@index([departmentId])
  @@index([supervisorUserId])
}

model ProjectMembership {
  id               String @id @default(cuid())
  userId           String
  projectId        String
  roleDefinitionId String

  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  project        Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  roleDefinition RoleDefinition @relation(fields: [roleDefinitionId], references: [id], onDelete: Restrict)

  @@unique([userId, projectId])
  @@index([projectId])
}

model Project {
  id              String        @id @default(cuid())
  companyId       String
  name            String
  description     String?
  ownerId         String
  status          ProjectStatus @default(PLANNING)
  priority        Priority      @default(MEDIUM)
  deadline        DateTime?
  progressPercent Int           @default(0)
  departmentId    String?
  projectGroupId  String?
  /// Sort order within a project group (or ungrouped list for that company).
  groupSortOrder  Int           @default(0)
  archivedAt      DateTime?
  deletedAt       DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  company      Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  department   Department?   @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  projectGroup ProjectGroup? @relation(fields: [projectGroupId], references: [id], onDelete: SetNull)
  owner        User          @relation("ProjectOwner", fields: [ownerId], references: [id])

  memberships       ProjectMembership[]
  layers            WorkflowLayer[]
  nodes             WorkflowNode[]
  edges             WorkflowEdge[]
  recognitions      RecognitionEvent[]
  feedbacks         FeedbackEvent[]
  knowledgeAssets   KnowledgeAsset[]
  outgoingRelations ProjectRelation[]   @relation("ProjectRelationFrom")
  incomingRelations ProjectRelation[]   @relation("ProjectRelationTo")
  attachments       Attachment[]        @relation("ProjectAttachment")
  memberOutputs     MemberOutput[]
  calendarEvents    CalendarEvent[]

  @@index([companyId])
  @@index([companyId, deletedAt])
  @@index([departmentId])
  @@index([projectGroupId])
  @@index([projectGroupId, groupSortOrder])
  @@index([deletedAt, status, deadline])
}

model ProjectRelation {
  id            String              @id @default(cuid())
  fromProjectId String
  toProjectId   String
  relationType  ProjectRelationType
  note          String?
  createdAt     DateTime            @default(now())

  fromProject       Project                           @relation("ProjectRelationFrom", fields: [fromProjectId], references: [id], onDelete: Cascade)
  toProject         Project                           @relation("ProjectRelationTo", fields: [toProjectId], references: [id], onDelete: Cascade)
  sharedKnowledge   ProjectRelationSharedKnowledge[]
  sharedAttachments ProjectRelationSharedAttachment[]

  @@unique([fromProjectId, toProjectId, relationType])
  @@index([fromProjectId])
  @@index([toProjectId])
}

/// Surface a knowledge asset from one side of a relation on the peer project page.
model ProjectRelationSharedKnowledge {
  id               String   @id @default(cuid())
  relationId       String
  knowledgeAssetId String
  createdAt        DateTime @default(now())

  relation       ProjectRelation @relation(fields: [relationId], references: [id], onDelete: Cascade)
  knowledgeAsset KnowledgeAsset  @relation(fields: [knowledgeAssetId], references: [id], onDelete: Cascade)

  @@unique([relationId, knowledgeAssetId])
  @@index([knowledgeAssetId])
}

/// Surface a project-level attachment link from one side of a relation on the peer project page.
model ProjectRelationSharedAttachment {
  id           String   @id @default(cuid())
  relationId   String
  attachmentId String
  createdAt    DateTime @default(now())

  relation   ProjectRelation @relation(fields: [relationId], references: [id], onDelete: Cascade)
  attachment Attachment      @relation(fields: [attachmentId], references: [id], onDelete: Cascade)

  @@unique([relationId, attachmentId])
  @@index([attachmentId])
}

model WorkflowLayer {
  id               String    @id @default(cuid())
  projectId        String
  name             String
  sortOrder        Int       @default(0)
  collapsedDefault Boolean   @default(false)
  deletedAt        DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  project Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  nodes   WorkflowNode[]

  @@index([projectId])
}

model WorkflowNode {
  id              String             @id @default(cuid())
  projectId       String
  layerId         String?
  parentNodeId    String?
  nodeType        WorkflowNodeType
  title           String
  description     String?
  status          WorkflowNodeStatus @default(NOT_STARTED)
  progressPercent Int                @default(0)
  posX            Float              @default(0)
  posY            Float              @default(0)
  sortOrder       Int                @default(0)
  archivedAt      DateTime?
  deletedAt       DateTime?
  dueAt           DateTime?
  operationalLabels WorkflowNodeLabel[] @default([])
  waitingOnUserId  String?
  waitingOnExternalName String?
  waitingDetails   String?
  waitingStartedAt DateTime?
  approverUserId   String?
  approvalRequestedAt DateTime?
  approvalCompletedAt DateTime?
  nextAction       String?
  isProjectBottleneck Boolean        @default(false)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  project      Project                @relation(fields: [projectId], references: [id], onDelete: Cascade)
  layer        WorkflowLayer?         @relation(fields: [layerId], references: [id], onDelete: SetNull)
  parent       WorkflowNode?          @relation("NodeTree", fields: [parentNodeId], references: [id], onDelete: SetNull)
  children     WorkflowNode[]         @relation("NodeTree")
  waitingOnUser User?                 @relation("NodeWaitingOnUser", fields: [waitingOnUserId], references: [id], onDelete: SetNull)
  waitingOnUsers WorkflowNodeWaitingUser[]
  approverUser User?                  @relation("NodeApproverUser", fields: [approverUserId], references: [id], onDelete: SetNull)
  assignees    WorkflowNodeAssignee[]
  edgesOut     WorkflowEdge[]         @relation("EdgeFrom")
  edgesIn      WorkflowEdge[]         @relation("EdgeTo")
  attachments  Attachment[]
  recognitions RecognitionEvent[]
  feedbacks    FeedbackEvent[]

  @@index([projectId])
  @@index([projectId, deletedAt, parentNodeId])
  @@index([projectId, deletedAt, status])
  @@index([projectId, deletedAt, dueAt])
  @@index([layerId])
  @@index([parentNodeId])
  @@index([waitingOnUserId])
  @@index([approverUserId])
}

model WorkflowNodeWaitingUser {
  id             String   @id @default(cuid())
  workflowNodeId String
  userId         String
  createdAt      DateTime @default(now())

  node WorkflowNode @relation(fields: [workflowNodeId], references: [id], onDelete: Cascade)
  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workflowNodeId, userId])
  @@index([userId])
}

model WorkflowNodeAssignee {
  id             String  @id @default(cuid())
  workflowNodeId String
  userId         String
  responsibility String?

  node WorkflowNode @relation(fields: [workflowNodeId], references: [id], onDelete: Cascade)
  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workflowNodeId, userId])
  @@index([userId])
}

model WorkflowEdge {
  id         String           @id @default(cuid())
  projectId  String
  fromNodeId String
  toNodeId   String
  kind       WorkflowEdgeKind @default(DEPENDENCY)
  label      String?
  deletedAt  DateTime?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  project  Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  fromNode WorkflowNode @relation("EdgeFrom", fields: [fromNodeId], references: [id], onDelete: Cascade)
  toNode   WorkflowNode @relation("EdgeTo", fields: [toNodeId], references: [id], onDelete: Cascade)

  @@unique([fromNodeId, toNodeId, kind])
  @@index([projectId])
  @@index([fromNodeId])
  @@index([toNodeId])
}

model Attachment {
  id                String                 @id @default(cuid())
  workflowNodeId    String?
  knowledgeAssetId  String?
  projectId         String?
  contributorUserId String?
  memberOutputId    String?
  previousVersionId String?
  resourceKind      AttachmentResourceKind @default(FILE)
  /// When resourceKind is EXTERNAL_URL, this is the canonical href (Drive, docs, etc.).
  externalUrl       String?
  fileName          String
  mimeType          String?
  sizeBytes         Int                    @default(0)
  /// Required for FILE; null for EXTERNAL_URL until uploads return in a later phase.
  storageKey        String?
  blobUrl           String?
  description       String?
  labels            String?
  titleEn           String?
  titleZh           String?
  uploadedById      String
  deletedAt         DateTime?
  createdAt         DateTime               @default(now())

  node            WorkflowNode?                     @relation(fields: [workflowNodeId], references: [id], onDelete: Cascade)
  knowledgeAsset  KnowledgeAsset?                   @relation("KnowledgeAttachment", fields: [knowledgeAssetId], references: [id], onDelete: Cascade)
  project         Project?                          @relation("ProjectAttachment", fields: [projectId], references: [id], onDelete: Cascade)
  contributor     User?                             @relation("AttachmentContributor", fields: [contributorUserId], references: [id], onDelete: SetNull)
  memberOutput    MemberOutput?                     @relation(fields: [memberOutputId], references: [id], onDelete: Cascade)
  previousVersion Attachment?                       @relation("AttachmentVersionChain", fields: [previousVersionId], references: [id], onDelete: SetNull)
  nextVersions    Attachment[]                      @relation("AttachmentVersionChain")
  uploadedBy      User                              @relation("AttachmentUploader", fields: [uploadedById], references: [id])
  relationShares  ProjectRelationSharedAttachment[]

  @@index([workflowNodeId])
  @@index([knowledgeAssetId])
  @@index([projectId])
  @@index([projectId, deletedAt, createdAt])
  @@index([contributorUserId])
  @@index([memberOutputId])
  @@index([previousVersionId])
}

model MemberOutput {
  id          String    @id @default(cuid())
  userId      String
  projectId   String?
  companyId   String?
  title       String
  titleEn     String?
  titleZh     String?
  description String?
  labels      String?
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  project     Project?     @relation(fields: [projectId], references: [id], onDelete: SetNull)
  company     Company?     @relation(fields: [companyId], references: [id], onDelete: SetNull)
  attachments Attachment[]

  @@index([userId, createdAt])
  @@index([projectId])
  @@index([companyId])
}

model RecognitionEvent {
  id                String                 @id @default(cuid())
  fromUserId        String?
  toUserId          String
  projectId         String?
  workflowNodeId    String?
  knowledgeAssetId  String?
  mode              RecognitionMode        @default(PUBLIC)
  tagCategory       RecognitionTagCategory
  secondaryLabelKey String                 @default("")
  tagLabel          String?
  message           String?
  createdAt         DateTime               @default(now())

  fromUser       User?           @relation("RecognitionFrom", fields: [fromUserId], references: [id], onDelete: SetNull)
  toUser         User            @relation("RecognitionTo", fields: [toUserId], references: [id], onDelete: Cascade)
  project        Project?        @relation(fields: [projectId], references: [id], onDelete: SetNull)
  node           WorkflowNode?   @relation(fields: [workflowNodeId], references: [id], onDelete: SetNull)
  knowledgeAsset KnowledgeAsset? @relation(fields: [knowledgeAssetId], references: [id], onDelete: SetNull)

  @@index([toUserId, createdAt])
  @@index([projectId, createdAt])
  @@index([knowledgeAssetId, createdAt])
}

model FeedbackEvent {
  id                String           @id @default(cuid())
  fromUserId        String?
  toUserId          String
  projectId         String?
  workflowNodeId    String?
  knowledgeAssetId  String?
  category          FeedbackCategory
  secondaryLabelKey String
  message           String?
  createdAt         DateTime         @default(now())

  fromUser       User?           @relation("FeedbackFrom", fields: [fromUserId], references: [id], onDelete: SetNull)
  toUser         User            @relation("FeedbackTo", fields: [toUserId], references: [id], onDelete: Cascade)
  project        Project?        @relation(fields: [projectId], references: [id], onDelete: SetNull)
  node           WorkflowNode?   @relation(fields: [workflowNodeId], references: [id], onDelete: SetNull)
  knowledgeAsset KnowledgeAsset? @relation(fields: [knowledgeAssetId], references: [id], onDelete: SetNull)

  @@index([toUserId, createdAt])
  @@index([projectId, createdAt])
}

model ScoreLedgerEntry {
  id                  String              @id @default(cuid())
  userId              String
  leaderboardCategory LeaderboardCategory
  abilityDimension    AbilityDimension?
  polarity            ScorePolarity       @default(POSITIVE)
  delta               Int
  reasonKey           String
  sourceType          String
  sourceId            String?
  companyId           String?
  projectId           String?
  createdAt           DateTime            @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([leaderboardCategory, createdAt])
  @@index([companyId, createdAt])
  @@index([projectId, createdAt])
}

model CompanionProfile {
  id                  String           @id @default(cuid())
  userId              String           @unique
  species             CompanionSpecies @default(BUNNY)
  /// Canonical manifest id (bird, bear, …); mirrors species for future growth systems.
  companionManifestId String?
  name                String?
  mood                String           @default("CURIOUS")
  level               Int              @default(1)
  selectedAt          DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PerformanceSnapshot {
  id                 String   @id @default(cuid())
  userId             String
  weekStart          DateTime
  executionScore     Int      @default(0)
  collaborationScore Int      @default(0)
  knowledgeScore     Int      @default(0)
  recognitionScore   Int      @default(0)
  trendDelta         Int      @default(0)
  createdAt          DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, weekStart])
  @@index([weekStart])
}

model KnowledgeAsset {
  id         String         @id @default(cuid())
  projectId  String?
  companyId  String?
  authorId   String
  title      String
  titleEn    String?
  titleZh    String?
  summary    String?
  content    String
  layer      KnowledgeLayer
  tags       String?
  sourceUrl  String?
  language   String?        @default("mixed")
  reuseCount Int            @default(0)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  deletedAt  DateTime?

  project        Project?                         @relation(fields: [projectId], references: [id], onDelete: SetNull)
  company        Company?                         @relation(fields: [companyId], references: [id], onDelete: SetNull)
  author         User                             @relation("KnowledgeAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  recognitions   RecognitionEvent[]
  feedbacks      FeedbackEvent[]
  reuses         KnowledgeReuseEvent[]
  attachments    Attachment[]                     @relation("KnowledgeAttachment")
  relationShares ProjectRelationSharedKnowledge[]

  @@index([layer, createdAt])
  @@index([projectId, createdAt])
  @@index([projectId, deletedAt, updatedAt])
  @@index([authorId, createdAt])
  @@index([companyId, createdAt])
}

model KnowledgeReuseEvent {
  id               String   @id @default(cuid())
  knowledgeAssetId String
  userId           String?
  createdAt        DateTime @default(now())

  asset KnowledgeAsset @relation(fields: [knowledgeAssetId], references: [id], onDelete: Cascade)
  user  User?          @relation("KnowledgeReuseActor", fields: [userId], references: [id], onDelete: SetNull)

  @@index([knowledgeAssetId, createdAt])
}

model AuditLogEntry {
  id         String          @id @default(cuid())
  actorId    String?
  entityType AuditEntityType
  entityId   String
  action     String
  field      String?
  oldValue   String?
  newValue   String?
  meta       String?
  createdAt  DateTime        @default(now())

  actor User? @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId])
}

/// Per-user per-company onboarding run (package + checklist + audit).
model MemberOnboarding {
  id                          String    @id @default(cuid())
  userId                      String
  companyId                   String
  packageUrl                  String
  packageVersion              String
  deadlineAt                  DateTime
  completedAt                 DateTime?
  liaisonUserId               String?
  liaisonName                 String?
  liaisonEmail                String?
  overdueSelfNotifiedAt       DateTime?
  overdueSupervisorNotifiedAt DateTime?
  /// User confirmed they opened the onboarding pack / primary materials (gates checklist).
  materialsOpenedAt           DateTime?
  /// Seconds of onboarding video consumed (HTML5) or dwell time for embed flows (capped server-side).
  videoProgressSeconds        Int       @default(0)
  /// Set when watch threshold met (e.g. ≥85% of duration or embed dwell target).
  videoCompletedAt            DateTime?
  createdAt                   DateTime  @default(now())
  updatedAt                   DateTime  @updatedAt

  user           User                            @relation(fields: [userId], references: [id], onDelete: Cascade)
  company        Company                         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  liaison        User?                           @relation("OnboardingLiaison", fields: [liaisonUserId], references: [id], onDelete: SetNull)
  checklistItems MemberOnboardingChecklistItem[]

  @@unique([userId, companyId])
  @@index([userId, completedAt])
  @@index([deadlineAt])
}

model MemberOnboardingChecklistItem {
  id           String    @id @default(cuid())
  onboardingId String
  itemKey      String
  sortOrder    Int       @default(0)
  completedAt  DateTime?

  onboarding MemberOnboarding @relation(fields: [onboardingId], references: [id], onDelete: Cascade)

  @@unique([onboardingId, itemKey])
  @@index([onboardingId])
}

model LifecycleTriggerRule {
  id           String                @id @default(cuid())
  kind         LifecycleTriggerKind
  windowDays   Int                   @default(30)
  threshold    Int                   @default(3)
  scope        LifecycleTriggerScope @default(GLOBAL)
  companyId    String?
  categoryMode LifecycleCategoryMode @default(TOTAL_COUNT)
  active       Boolean               @default(true)
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  company Company?               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  fires   LifecycleTriggerFire[]

  @@index([kind, active])
  @@index([companyId])
}

model LifecycleTriggerFire {
  id                  String    @id @default(cuid())
  ruleId              String
  subjectUserId       String
  windowStart         DateTime
  windowEnd           DateTime
  triggeredAt         DateTime  @default(now())
  /// JSON array of FeedbackEvent or RecognitionEvent ids (strings).
  sourceEventIds      String
  followUpCompletedAt DateTime?

  rule    LifecycleTriggerRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  subject User                 @relation(fields: [subjectUserId], references: [id], onDelete: Cascade)

  @@unique([ruleId, subjectUserId, windowStart])
  @@index([subjectUserId])
}

model LifecycleReminderLog {
  id              String   @id @default(cuid())
  kind            String
  recipientUserId String
  relatedType     String?
  relatedId       String?
  payload         Json?
  createdAt       DateTime @default(now())

  recipient User @relation(fields: [recipientUserId], references: [id], onDelete: Cascade)

  @@index([recipientUserId, createdAt])
}

model InAppNotification {
  id        String    @id @default(cuid())
  userId    String
  kind      String
  title     String
  body      String?
  href      String?
  readAt    DateTime?
  metadata  Json?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt, createdAt])
}

model OffboardingRun {
  id                   String            @id @default(cuid())
  userId               String
  companyId            String
  status               OffboardingStatus @default(IN_PROGRESS)
  startedById          String
  startedAt            DateTime          @default(now())
  completedAt          DateTime?
  accountDeactivatedAt DateTime?
  notes                String?

  user      User                       @relation("OffboardingSubject", fields: [userId], references: [id], onDelete: Cascade)
  company   Company                    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  startedBy User                       @relation("OffboardingStartedBy", fields: [startedById], references: [id], onDelete: Restrict)
  checklist OffboardingChecklistItem[]

  @@index([companyId, status])
  @@index([userId])
}

model OffboardingChecklistItem {
  id          String    @id @default(cuid())
  runId       String
  itemKey     String
  label       String
  completedAt DateTime?

  run OffboardingRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@unique([runId, itemKey])
  @@index([runId])
}

model CalendarLabel {
  id        String   @id @default(cuid())
  /// Stable key for built-in labels; custom labels keep this null.
  key       String?  @unique
  name      String
  color     String   @default("#6366f1")
  sortOrder Int      @default(0)
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  events CalendarEvent[]

  @@index([sortOrder])
}

model CalendarEvent {
  id                      String             @id @default(cuid())
  title                   String
  description             String?
  startsAt                DateTime
  endsAt                  DateTime
  timezone                String             @default("UTC")
  organizerUserId         String
  projectId               String?
  labelId                 String?
  sourceKind              CalendarSourceKind @default(MANUAL)
  sourceId                String?
  meetUrl                 String?
  /// Guest emails without user accounts (e.g. external interviews).
  externalAttendeeEmails  String[]           @default([])
  externalCalendarEventId String?
  createdAt               DateTime           @default(now())
  updatedAt               DateTime           @updatedAt

  organizer User               @relation("CalendarOrganizer", fields: [organizerUserId], references: [id], onDelete: Cascade)
  project   Project?           @relation(fields: [projectId], references: [id], onDelete: SetNull)
  label     CalendarLabel?     @relation(fields: [labelId], references: [id], onDelete: SetNull)
  attendees CalendarAttendee[]

  @@index([organizerUserId, startsAt])
  @@index([projectId])
  @@index([labelId])
  @@index([projectId, startsAt])
}

model CalendarAttendee {
  id      String @id @default(cuid())
  eventId String
  userId  String

  event CalendarEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@index([userId])
}
