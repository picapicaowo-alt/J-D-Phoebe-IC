# --- MySQL ---
# Local docker-compose default (matches docker-compose.yml in this repo).
DATABASE_URL="mysql://jdphoebe:jdphoebe@localhost:3306/jdphoebe"
#
# Production / managed MySQL (PlanetScale, RDS, Aliyun RDS, Vercel Marketplace, etc.).
# Use connection pooling at the database side or via a dedicated proxy; Prisma's mysql driver
# opens one connection per PrismaClient instance — keep one PrismaClient per Node process.
# Example shapes:
#   DATABASE_URL="mysql://user:password@host:3306/jdphoebe?ssl={\"rejectUnauthorized\":true}"
#   DATABASE_URL="mysql://user:password@host:3306/jdphoebe?connection_limit=10&pool_timeout=15"
#
# Setup:
# 1) Provision a MySQL 8.x database, create an empty schema (e.g. `jdphoebe`).
# 2) Set DATABASE_URL above, then from this repo:
#      npm run db:push   # syncs prisma/schema.prisma to MySQL
#      npm run db:seed   # seeds demo data
# 3) Seed creates demo accounts (password demo1234 for all), e.g. admin@jdphoebe.local, group.admin@jdphoebe.local,
#    legal.admin@jdphoebe.local, pm@jdphoebe.local, staff@jdphoebe.local, onboarding.demo@jdphoebe.local
# 4) Deploy the Next app (e.g. Vercel) with the same DATABASE_URL; users sign in at /login with those emails.

# Iron-session (password login fallback when Clerk is not configured)
# Must be at least 32 characters (iron-session requirement). Generate e.g. openssl rand -hex 32
SESSION_SECRET="replace-with-long-random-string!"

# Optional: Clerk (when both are set, middleware protects routes and getCurrentUser uses Clerk)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Optional: Vercel Blob for workflow attachments plus company logos / staff avatars on Vercel.
# Local development can fall back to ./uploads and public/uploads without this token.
# This app also accepts a single Vercel-generated Blob token with a custom store prefix, like MY_STORE_READ_WRITE_TOKEN.
BLOB_READ_WRITE_TOKEN=

# Optional: Resend (transactional email fallback)
RESEND_API_KEY=
# Sender shown to recipients.
# For Namecheap Private Email, a good default is:
#   EMAIL_FROM="J.D. Phoebe Group DO NOT REPLY <info@jdphoebe.com>"
EMAIL_FROM=

# Optional: SMTP (works well with Namecheap Private Email)
# Namecheap official settings: host mail.privateemail.com, port 465 for SSL or 587 for TLS/STARTTLS.
# If the mailbox uses 2FA, use a Namecheap app-specific password for SMTP_PASS.
SMTP_HOST=mail.privateemail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=

# Optional: separate secret for OTP HMAC (defaults to SESSION_SECRET when unset)
OTP_SECRET=
# Optional: separate secret for account setup links (defaults to PASSWORD_RESET_SECRET / OTP_SECRET / SESSION_SECRET)
ACCOUNT_SETUP_SECRET=
