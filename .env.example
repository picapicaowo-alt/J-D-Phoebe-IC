# PostgreSQL (docker-compose: postgresql://postgres:postgres@localhost:5432/jdphoebe)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/jdphoebe"
# Same DB, non-pooler URL (Prisma migrations / db push). Local Docker: copy DATABASE_URL.
# Supabase (dashboard → Project Settings → Database): use "Session mode" / pooler URI for DATABASE_URL when
# recommended, and "Direct connection" or transaction pooler URI for DIRECT_URL (see current Supabase docs).
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/jdphoebe"
#
# --- Hosting the app DB on Supabase (login users live in table "User", not Supabase Auth) ---
# 1) Create a Supabase project → copy connection strings into DATABASE_URL and DIRECT_URL above.
# 2) From this repo: npm run db:push   then   npm run db:seed
# 3) Seed creates demo accounts (password demo1234 for all), e.g. admin@jdphoebe.local, group.admin@jdphoebe.local,
#    legal.admin@jdphoebe.local, pm@jdphoebe.local, staff@jdphoebe.local, onboarding.demo@jdphoebe.local
# 4) Deploy the Next app (e.g. Vercel) with the same env vars; users sign in at /login with those emails.
# Optional: enable RLS on public tables only if you expose the DB via Supabase Data API; this app uses server-side Prisma.

# Iron-session (password login fallback when Clerk is not configured)
# Must be at least 32 characters (iron-session requirement). Generate e.g. openssl rand -hex 32
SESSION_SECRET="replace-with-long-random-string!"

# Optional: Clerk (when both are set, middleware protects routes and getCurrentUser uses Clerk)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Optional: Vercel Blob for workflow attachments (otherwise files go to ./uploads)
BLOB_READ_WRITE_TOKEN=

# Optional: Resend (staff invite OTP + lifecycle email). In development, OTPs are logged if RESEND_API_KEY is unset.
RESEND_API_KEY=
# Sender shown to recipients (must be allowed in Resend for your domain)
EMAIL_FROM=

# Optional: separate secret for OTP HMAC (defaults to SESSION_SECRET when unset)
OTP_SECRET=
